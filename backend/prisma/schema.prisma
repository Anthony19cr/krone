generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Frequency {
  MONTHLY
  BIWEEKLY
  ONE_TIME
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum Currency {
  CRC
  USD
  EUR
  MXN
  COP
  ARS
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  passwordHash String
  currency     Currency     @default(CRC)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  categories   Category[]
  incomes      Income[]
  expenses     Expense[]
  debts        Debt[]
  savingGoals  SavingGoal[]
}

// ---------------------------------------------------------------------------
// Category
// ---------------------------------------------------------------------------

model Category {
  id        Int          @id @default(autoincrement())
  name      String
  type      CategoryType
  color     String       @default("#6b7280")
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  incomes  Income[]
  expenses Expense[]

  @@unique([name, type, userId])
}

// ---------------------------------------------------------------------------
// Income
// ---------------------------------------------------------------------------

model Income {
  id          Int       @id @default(autoincrement())
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  recurring   Boolean   @default(false)
  frequency   Frequency @default(ONE_TIME)
  month       Int       // 1–12
  year        Int
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Expense
// ---------------------------------------------------------------------------

model Expense {
  id          Int       @id @default(autoincrement())
  name        String
  amount      Decimal   @db.Decimal(12, 2)
  recurring   Boolean   @default(false)
  frequency   Frequency @default(ONE_TIME)
  month       Int       // 1–12
  year        Int
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Debt
// ---------------------------------------------------------------------------

model Debt {
  id              Int      @id @default(autoincrement())
  name            String
  totalAmount     Decimal  @db.Decimal(12, 2)
  remainingAmount Decimal  @db.Decimal(12, 2)
  totalPayments   Int
  paidPayments    Int      @default(0)
  annualRate      Decimal  @db.Decimal(5, 2)  // percentage, e.g. 18.00
  monthlyPayment  Decimal  @db.Decimal(12, 2)  // calculated on create/update
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Saving Goal
// ---------------------------------------------------------------------------

model SavingGoal {
  id            Int      @id @default(autoincrement())
  name          String
  targetAmount  Decimal  @db.Decimal(12, 2)
  currentAmount Decimal  @db.Decimal(12, 2) @default(0)
  targetDate    DateTime?
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
